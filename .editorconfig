# EditorConfig - https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
indent_size = 4
# Project line-length limit. Raised from ktlint's default (typically 120) to 180
# to match detekt.yml MaxLineLength — protocol documentation comments,
# audio/mic format notes, and log lines with interpolated variables legitimately
# exceed 140 and should not be wrapped at the cost of legibility.
max_line_length = 180

# ktlint configuration
ktlint_standard_no-unused-imports = enabled
# Composable functions use PascalCase per Jetpack Compose API Guidelines
# https://github.com/androidx/androidx/blob/androidx-main/compose/docs/compose-api-guidelines.md
ktlint_function_naming_ignore_when_annotated_with = Composable

[*.{java}]
indent_size = 4

[*.{xml,json}]
indent_size = 4

[*.{gradle,gradle.kts}]
indent_size = 4

[*.md]
trim_trailing_whitespace = false
